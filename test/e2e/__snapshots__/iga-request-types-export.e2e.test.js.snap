            "_meta": {
              "display": "User Deletion",
              "properties": {
                "userId": {
                  "display": {
                    "description": "The ID of the user being deleted",
                    "isVisible": true,
                    "name": "User",
                    "order": 1,
                  },
                  "isInternal": true,
                  "isMultiValue": false,
                  "isRequired": true,
                  "lookup": {
                    "path": "/openidm/managed/user",
                  },
