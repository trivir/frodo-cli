          {
            "_meta": {
              "display": "Account Grant",
              "properties": {
                "applicationId": {
                  "display": {
                    "description": "The application that is granted to the user",
                    "isVisible": true,
                    "name": "Application",
                    "order": 1,
                  },
                  "isInternal": true,
                  "isMultiValue": false,
                  "isRequired": true,
                  "lookup": {
                    "path": "/iga/index/catalog",
                    "query": "application/id/keyword eq "\${applicationId}" and item/type/keyword eq "accountGrant"",
                  },
                },
                "userId": {
                  "display": {
                    "description": "The user who is granted the application",
                    "isVisible": true,
                    "name": "User",
                    "order": 1,
                  },
                  "isInternal": true,
                  "isMultiValue": false,
                  "isRequired": true,
                  "lookup": {
                    "path": "/openidm/managed/user",
                  },
