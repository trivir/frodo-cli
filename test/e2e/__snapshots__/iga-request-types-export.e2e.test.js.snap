                    "name": "Entitlement",
                    "order": 1,
                  },
                  "isInternal": true,
                  "isMultiValue": false,
                  "isRequired": true,
                  "lookup": {
                    "path": "/iga/index/catalog",
                    "query": "assignment/id/keyword eq "\${entitlementId}" and item/type/keyword eq "entitlementGrant"",
                  },
                },
                "userId": {
                  "display": {
                    "description": "The user who should be granted the entitlement",
                    "isVisible": true,
                    "name": "User",
