        "fr": "Créer un nouveau compte",
      },
    },
    "requestAssigned": {
      "_id": "emailTemplate/requestAssigned",
      "defaultLocale": "en",
      "enabled": true,
      "from": "",
      "message": {
        "en": "<html><head></head><body>>A Request was assigned to you to approve access for {{object.user.givenName}} {{object.user.sn}}, please review at your earliest convenience.</body></html>",
      },
      "mimeType": "text/html",
      "subject": {
        "en": "ATTENTION: Request Assigned",
      },
    },
    "requestEscalated": {
      "_id": "emailTemplate/requestEscalated",
      "defaultLocale": "en",
      "enabled": true,
      "from": "",
      "message": {
        "en": "<html><head></head><body>A request approval has been escalated to your attention.</body></html>",
      },
