      },
    },
    "requestExpired": {
      "_id": "emailTemplate/requestExpired",
      "defaultLocale": "en",
      "enabled": true,
      "from": "",
      "message": {
        "en": "<html><head></head><body> A request approval assigned to you has expired.</body></html>",
      },
