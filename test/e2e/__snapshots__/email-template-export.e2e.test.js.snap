    "certificationAssigned": {
      "_id": "emailTemplate/certificationAssigned",
      "defaultLocale": "en",
      "enabled": true,
      "from": "",
      "message": {
        "en": "<html><head></head><body>Hello, {{object.user.givenName}} {{object.user.sn}}! <br> A certification task for the campaign {{object.campaign.name}} was assigned to you.</body></html>",
      },
      "mimeType": "text/html",
      "subject": {
        "en": "ATTENTION: Certification Task Assigned",
      },
    },
  },
  "meta": Any<Object>,
}
`;

