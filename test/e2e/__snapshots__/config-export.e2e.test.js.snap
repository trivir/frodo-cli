exports[`frodo config export "frodo config export -AxNosD exportAllTestDir10": should export all separated files with extracted idm scripts.: exportAllTestDir10/realm/root-alpha/script/Check-Username.script.js 1`] = `
"/* Check Username
 *
 * Author: volker.scheuber@forgerock.com
 * 
 * Check if username has already been collected.
 * Return "known" if yes, "unknown" otherwise.
 * 
 * This script does not need to be parametrized. It will work properly as is.
 * 
 * The Scripted Decision Node needs the following outcomes defined:
 * - known
 * - unknown
 */
(function () {
    if (null != sharedState.get("username")) {
        outcome = "known";
    }
    else {
        outcome = "unknown";
    }
}());
"
`;

