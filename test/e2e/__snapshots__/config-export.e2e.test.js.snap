        "general": {
          "bufferSize": 25,
          "bufferTime": 60,
          "buffering": "ON",
          "certificateStore": "%BASE_DIR%/var/audit/Logger.jks",
          "fields": [
            "IPAddr",
            "LoggedBy",
            "LoginID",
            "NameID",
            "ModuleName",
            "ContextID",
            "Domain",
            "LogLevel",
            "HostName",
            "MessageID",
          ],
          "filesPerKeystore": 5,
          "jdkLoggingLevel": "INFO",
          "security": "OFF",
          "signaturePeriod": 900,
          "signingAlgorithm": "SHA1withRSA",
          "status": "INACTIVE",
          "type": "File",
          "verifyPeriod": 3600,
        },
        "location": "global",
