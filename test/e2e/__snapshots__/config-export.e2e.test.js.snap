        "9de3eb62-f131-4fac-a294-7bd170fd4acb": {
          "_id": "9de3eb62-f131-4fac-a294-7bd170fd4acb",
          "context": "POLICY_CONDITION",
          "createdBy": "null",
          "creationDate": 0,
          "default": true,
