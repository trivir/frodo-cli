          "evaluatorVersion": "1.0",
          "language": "JAVASCRIPT",
          "name": "Device Id (Match) - Server Side",
          "script": "/*
 * DO NOT ALTER OR REMOVE COPYRIGHT NOTICES OR THIS HEADER.
