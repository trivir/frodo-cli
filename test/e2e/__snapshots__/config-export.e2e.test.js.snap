          "roles": "*",
        },
        {
          "actions": "login,logout",
          "methods": "read,action",
          "pattern": "authentication",
          "roles": "*",
        },
        {
          "actions": "*",
          "methods": "*",
          "pattern": "config/fidc/*",
          "roles": "internal/role/openidm-admin",
        },
        {
          "actions": "*",
          "methods": "read",
          "pattern": "config/ui/themeconfig",
          "roles": "*",
        },
