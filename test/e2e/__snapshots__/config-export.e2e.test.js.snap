        "file": {
          "location": "%BASE_DIR%/var/audit/",
          "maxFileSize": 100000000,
          "numberHistoryFiles": 1,
          "rotationEnabled": true,
          "rotationInterval": -1,
          "suffix": "-MM.dd.yy-kk.mm",
