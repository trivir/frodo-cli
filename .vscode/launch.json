{
  "version": "0.2.0",
  "configurations": [
    
    {
      "type": "node",
      "request": "launch",
      "name": "Run Frodo CLI",
      "program": "${workspaceFolder}/src/app.ts",
      "args": ["journey", "export", "-a", "-D", "toss", "d"],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.(m|c|)js",
        "${workspaceFolder}/node_modules/@rockcarver/frodo-lib/dist/**/*.(m|c|)js"
      ]
    }
  ]
}